{
  "name": "potex-gas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run typecheck && node ./scripts/build-gas.mjs",
    "push": "PATH=/home/ubuntu/.hermes/node/bin:$PATH clasp push -f -A $HOME/.clasprc.json",
    "pull": "PATH=/home/ubuntu/.hermes/node/bin:$PATH clasp pull -A $HOME/.clasprc.json",
    "deploy": "npm run build && PATH=/home/ubuntu/.hermes/node/bin:$PATH clasp push -f -A $HOME/.clasprc.json",
    "open": "PATH=/home/ubuntu/.hermes/node/bin:$PATH clasp open -A $HOME/.clasprc.json",
    "logs": "PATH=/home/ubuntu/.hermes/node/bin:$PATH clasp logs --watch -A $HOME/.clasprc.json"
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^1.0.83",
    "esbuild": "^0.25.5",
    "typescript": "^5.6.3"
  }
}
